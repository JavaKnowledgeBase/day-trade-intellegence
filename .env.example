APP_NAME=Day Trade Intelligence
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1
ALPACA_API_KEY=replace-me
ALPACA_SECRET_KEY=replace-me
ALPACA_DATA_FEED=iex
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
DATABASE_URL=sqlite:///./day_trade_intelligence.db
REDIS_URL=redis://localhost:6379/0
MAX_CAPITAL_AT_RISK_PCT=0.02
MAX_DRAWDOWN_PCT=0.10
DEFAULT_STOP_LOSS_PCT=0.01
PAPER_ACCOUNT_EQUITY=100000
PAPER_BUYING_POWER=250000
SEED_DEMO_DATA=true
BOOTSTRAP_SCHEMA=true
RUN_MIGRATIONS_ON_START=false
TRADER_API_KEY=trader-local-key
OPERATOR_API_KEY=operator-local-key
ADMIN_API_KEY=admin-local-key
AUTH_SECRET_KEY=change-this-local-auth-secret
AUTH_TOKEN_EXP_MINUTES=480
