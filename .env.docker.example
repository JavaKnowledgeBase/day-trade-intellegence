APP_NAME=Day Trade Intelligence
ENVIRONMENT=production
LOG_LEVEL=INFO
API_PREFIX=/api/v1
ALPACA_API_KEY=replace-me
ALPACA_SECRET_KEY=replace-me
ALPACA_DATA_FEED=iex
IBKR_HOST=host.docker.internal
IBKR_PORT=7497
IBKR_CLIENT_ID=1
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/day_trade_intelligence
REDIS_URL=redis://redis:6379/0
MAX_CAPITAL_AT_RISK_PCT=0.02
MAX_DRAWDOWN_PCT=0.10
DEFAULT_STOP_LOSS_PCT=0.01
PAPER_ACCOUNT_EQUITY=100000
PAPER_BUYING_POWER=250000
SEED_DEMO_DATA=false
BOOTSTRAP_SCHEMA=false
RUN_MIGRATIONS_ON_START=true
TRADER_API_KEY=replace-me
OPERATOR_API_KEY=replace-me
ADMIN_API_KEY=replace-me
AUTH_SECRET_KEY=replace-me-with-a-long-secret
AUTH_TOKEN_EXP_MINUTES=480
